# Copy to .env and adjust as needed.

# Neo4j credentials (used by both the neo4j and backend containers)
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123

# Where the backend can reach your existing Ollama container.
# Default assumes the Ollama container publishes 11434 on the host.
# If your Ollama container is on a shared docker network instead, use
# e.g. http://ollama:11434 and attach the backend to that network.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Models (must be pulled inside your Ollama container beforehand)
GENERATION_MODEL=gemma2:9b
EMBEDDING_MODEL=nomic-embed-text
